# ============================================================
# Configuration de l'application
# ============================================================
APP_NAME="Calvino"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=fr

# ============================================================
# Base de données
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=calvino_db
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ============================================================
# JWT (JSON Web Token)
# ============================================================
JWT_SECRET=your-secret-key-here-change-this-in-production-min-32-chars
# Durée de vie du token d'accès en secondes (défaut : 24h)
JWT_TTL=86400
# Durée de vie du refresh token en secondes (défaut : 30 jours)
JWT_REFRESH_TTL=2592000

# ============================================================
# Rate Limiting (ThrottleMiddleware)
# ============================================================
# Nombre maximum de tentatives dans la fenêtre de temps
RATE_LIMIT_MAX=5
# Durée de la fenêtre en secondes
RATE_LIMIT_DECAY=60

# ============================================================
# API
# ============================================================
API_VERSION=1.0
API_PREFIX=/api

# ============================================================
# CORS
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_HEADERS="Content-Type, Authorization, X-Requested-With, Accept, Origin, X-Auth-Token"
CORS_ALLOWED_METHODS="GET, POST, PUT, DELETE, PATCH, OPTIONS"
CORS_MAX_AGE=86400
CORS_ALLOW_CREDENTIALS=true

# ============================================================
# Sessions
# ============================================================
USE_SESSIONS=true
SESSION_LIFETIME=120

# ============================================================
# Mail (pour l'envoi des liens de réinitialisation de mdp)
# ============================================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@calvino.app
MAIL_FROM_NAME="${APP_NAME}"
